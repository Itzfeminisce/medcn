{
  "name": "progress",
  "title": "Progress",
  "description": "Progress bar with size and status-color variants — used for adherence, plan completion, and intake progress.",
  "category": "primitives",
  "type": "registry:ui",
  "version": "0.1.0",
  "dependencies": ["@radix-ui/react-progress", "class-variance-authority"],
  "registryDependencies": ["utils"],
  "props": [
    { "name": "value", "type": "number", "description": "0–100." },
    { "name": "size", "type": "\"sm\" | \"default\" | \"lg\"", "default": "\"default\"" },
    { "name": "variant", "type": "\"default\" | \"success\" | \"warning\" | \"destructive\"", "default": "\"default\"", "description": "Indicator color." }
  ],
  "notes": "Ported from petals_ui; Petals `pink`/`teal` variants removed."
}
